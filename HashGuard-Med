    "import os, glob, time, json, random, shutil\n",
    "from pathlib import Path\n",
    "import numpy as np, pandas as pd\n",
    "\n",
    "# ---------------- experiment config ----------------\n",
    "TARGET_POS    = \"Pneumonia\"    # try \"Effusion\"/\"Atelectasis\"/\"Infiltration\" for a larger set\n",
    "PER_CLASS_CAP = 5000\n",
    "IMG_SIZE      = 224\n",
    "SEED          = 42\n",
    "EPOCHS        = 5\n",
    "BATCH         = 32\n",
    "LR            = 1e-4\n",
    "POISON_RATES  = [0.0, 0.05, 0.10, 0.20]\n",
    "random.seed(SEED); np.random.seed(SEED)\n",
    "\n",
    "WORK   = Path(\"/kaggle/working\")\n",
    "STORE  = WORK / \"secure_store\"\n",
    "DBP    = WORK / \"secure.db\"\n",
    "KEYS   = WORK / \"keys\"\n",
    "RESULTS= WORK / \"results\"; RESULTS.mkdir(exist_ok=True, parents=True)\n",
    "INPUT  = Path(\"/kaggle/input\")\n",
    "idxcol = \"Image Index\"\n",
    "\n",
    "# ---- show what is actually mounted ----\n",
    "tops = sorted(p.name for p in INPUT.glob(\"*\"))\n",
    "print(\"Attached under /kaggle/input:\", tops or \"(nothing — click Add Input and wait for the mount)\")\n",
    "assert tops, \"No dataset mounted. Add Input -> NIH Chest X-rays, wait a few seconds, re-run.\"\n",
    "\n",
    "# ---- robust recursive image index via os.walk (handles images_00X/images/*.png) ----\n",
    "IMG_EXT = (\".png\", \".jpg\", \".jpeg\")\n",
    "print(\"indexing images (walking the tree)...\")\n",
    "img_index = {}\n",
    "for dirpath, _, files in os.walk(INPUT):\n",
    "    for f in files:\n",
    "        if f.lower().endswith(IMG_EXT):\n",
    "            img_index.setdefault(f, os.path.join(dirpath, f))\n",
    "print(f\"indexed {len(img_index):,} images\")\n",
    "assert img_index, (\"Still no images. The mount may not be ready — wait 10s and re-run, \"\n",
    "                   \"or confirm images_001..012 appear in the right-hand data panel.\")\n",
    "print(\"sample image path:\", next(iter(img_index.values())))\n",
    "\n",
    "# ---- find the labels CSV (Data_Entry_2017.csv is in this dataset) ----\n",
    "def find_label_csv():\n",
    "    hits = glob.glob(str(INPUT/\"**\"/\"Data_Entry_2017.csv\"), recursive=True)\n",
    "    if hits: return hits[0]\n",
    "    for c in glob.glob(str(INPUT/\"**\"/\"*.csv\"), recursive=True):\n",
    "        try:\n",
    "            cols = [x.strip() for x in pd.read_csv(c, nrows=1).columns]\n",
    "            if \"Finding Labels\" in cols and \"Image Index\" in cols:\n",
    "                return c\n",
    "        except Exception:\n",
    "            pass\n",
    "    return None\n",
    "\n",
    "CSV = find_label_csv()\n",
    "MODE = \"csv\" if CSV else \"folderwise\"\n",
    "print(\"label source:\", MODE, \"|\", CSV or \"(none)\")"
