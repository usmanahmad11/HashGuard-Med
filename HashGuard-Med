    "df = df[df[idxcol].isin(img_index)].copy()\n",
    "\n",
    "has_pos = df[labcol].str.contains(TARGET_POS, regex=False, na=False)\n",
    "is_neg  = df[labcol].eq(\"No Finding\")\n",
    "pos, neg = df[has_pos].copy(), df[is_neg].copy()\n",
