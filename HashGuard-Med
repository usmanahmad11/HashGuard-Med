    "def poisoned_loader(rate):\n",
    "    ids = ids_for(\"train\"); y = {i:int(data[data[idxcol]==i].y.iloc[0]) for i in ids}\n",
    "    flip = set(rng.choice(ids, size=int(rate*len(ids)), replace=False)) if rate>0 else set()\n",
    "    class PDS(Dataset):\n",
    "        def __len__(self): return len(ids)\n",
    "        def __getitem__(self, k):\n",
    "            iid=ids[k]\n",
    "            row=db.conn.execute(\"SELECT file_path FROM images WHERE image_id=?\", (iid,)).fetchone()\n",
    "            arr=np.asarray(Image.open(row[0]),dtype=np.uint8)\n",
    "            lab=y[iid] ^ (1 if iid in flip else 0)\n",
    "            return tf(arr), lab\n",
    "    return DataLoader(PDS(), batch_size=BATCH, shuffle=True, num_workers=2, pin_memory=True)\n",
    "\n",
    "poison_curve=[]\n",
    "for rate in POISON_RATES:\n",
    "    torch.manual_seed(SEED)\n",
    "    m = build_model()\n",
    "    print(f\"poison rate {rate:.0%} ...\")\n",
    "    train(m, poisoned_loader(rate), epochs=EPOCHS)\n",
    "    met = evaluate(m, make_loader(\"test\",\"unsecured\",False))\n",
    "    poison_curve.append({\"rate\":rate, **{k:round(v,4) for k,v in met.items()}})\n",
    "    print(\"  ->\", poison_curve[-1])\n",
    "pd.DataFrame(poison_curve).to_csv(RESULTS/\"poison_curve.csv\", index=False)"
   ]
