    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "df = pd.read_csv(CSV)\n",
    "df.columns = [c.strip() for c in df.columns]\n",
    "labcol = \"Finding Labels\" if \"Finding Labels\" in df.columns else df.columns[1]\n",
