





get_ipython().run_cell_magic("writefile", " securedb.py", """\"\"\"
HashGuard-Med: Tamper-evident, hash-chained, signed image database
for trustworthy medical image classification.

Contribution module for the research paper. Provides:
  - SHA-256 hash chain over ingested images (Merkle-style linear chain)
  - Ed25519 signatures binding {image_hash, label, metadata} at ingestion
  - verify_and_load(): integrity + authenticity check before an image
    reaches the ML DataLoader
  - verify_chain_full(): walks the whole chain, reports first broken link
  - Tamper-evident audit log of every verification event

Design note on threat coverage:
  * A1 image substitution/manipulation -> caught by SHA-256 hash mismatch
  * A2 label-flip poisoning            -> caught by signature (label is signed)
  * A3 unauthenticated injection       -> caught by signature (wrong key)
\"\"\"

from __future__ import annotations

import json
import sqlite3
import hashlib
import datetime as _dt
from pathlib import Path
from typing import Optional

import numpy as np
from PIL import Image

from cryptography.hazmat.primitives.asymmetric.ed25519 import (
    Ed25519PrivateKey,
    Ed25519PublicKey,
)
from cryptography.hazmat.primitives import serialization
from cryptography.exceptions import InvalidSignature

GENESIS_PREV = "0" * 64


# --------------------------------------------------------------------------- #
# Key management (represents the "acquisition device" identity)
# --------------------------------------------------------------------------- #
def generate_device_keypair(key_dir: str | Path) -> tuple[Path, Path]:
    \"\"\"Generate an Ed25519 keypair and write PEM files. Returns (priv, pub).\"\"\"
    key_dir = Path(key_dir)
    key_dir.mkdir(parents=True, exist_ok=True)
    priv = Ed25519PrivateKey.generate()

    priv_path = key_dir / "device_private.pem"
    pub_path = key_dir / "device_public.pem"

    priv_path.write_bytes(
        priv.private_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PrivateFormat.PKCS8,
            encryption_algorithm=serialization.NoEncryption(),
        )
    )
    pub_path.write_bytes(
        priv.public_key().public_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PublicFormat.SubjectPublicKeyInfo,
        )
    )
    return priv_path, pub_path


def load_private_key(path: str | Path) -> Ed25519PrivateKey:
    return serialization.load_pem_private_key(Path(path).read_bytes(), password=None)


def load_public_key(path: str | Path) -> Ed25519PublicKey:
    return serialization.load_pem_public_key(Path(path).read_bytes())


# --------------------------------------------------------------------------- #
# Canonical hashing helpers
# --------------------------------------------------------------------------- #
def sha256_image(arr: np.ndarray) -> str:
    \"\"\"Hash the raw pixel bytes of a uint8 image array (deterministic).\"\"\"
    return hashlib.sha256(np.ascontiguousarray(arr, dtype=np.uint8).tobytes()).hexdigest()


def signed_payload(image_sha: str, label: int, meta: dict) -> bytes:
    \"\"\"
    Canonical bytes that get signed. Binding the label + meta into the
    signature is what makes label-flip poisoning (A2) detectable.
    \"\"\"
    payload = {
        "image_sha": image_sha,
        "label": int(label),
        "meta": meta,
    }
    return json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")


def compute_chain_hash(image_sha: str, prev_hash: str) -> str:
    return hashlib.sha256((image_sha + prev_hash).encode("utf-8")).hexdigest()


# --------------------------------------------------------------------------- #
# The secure database
# --------------------------------------------------------------------------- #
class SecureImageDB:
    def __init__(self, db_path: str | Path, image_store: str | Path):
        self.db_path = str(db_path)
        self.image_store = Path(image_store)
        self.image_store.mkdir(parents=True, exist_ok=True)
        self.conn = sqlite3.connect(self.db_path)
        self.conn.execute("PRAGMA journal_mode=WAL;")
        self._init_schema()

    def _init_schema(self) -> None:
        self.conn.executescript(
            \"\"\"
            CREATE TABLE IF NOT EXISTS images (
                image_id     TEXT PRIMARY KEY,
                seq          INTEGER,
                sha256       TEXT NOT NULL,
                prev_hash    TEXT NOT NULL,
                chain_hash   TEXT NOT NULL,
                signature    TEXT NOT NULL,
                label        INTEGER NOT NULL,
                meta         TEXT NOT NULL,
                file_path    TEXT NOT NULL,
                ingested_at  TEXT NOT NULL
            );
            CREATE TABLE IF NOT EXISTS audit (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                image_id    TEXT,
                event       TEXT NOT NULL,
                result      TEXT NOT NULL,
                detail      TEXT,
                ts          TEXT NOT NULL
            );
            \"\"\"
        )
        self.conn.commit()

    # ----------------------------- audit -------------------------------- #
    def _log(self, image_id: Optional[str], event: str, result: str, detail: str = "") -> None:
        self.conn.execute(
            "INSERT INTO audit (image_id, event, result, detail, ts) VALUES (?,?,?,?,?)",
            (image_id, event, result, detail, _dt.datetime.utcnow().isoformat()),
        )
        self.conn.commit()

    # ----------------------------- helpers ------------------------------ #
    def _last_row(self):
        return self.conn.execute(
            "SELECT seq, chain_hash FROM images ORDER BY seq DESC LIMIT 1"
        ).fetchone()

    def count(self) -> int:
        return self.conn.execute("SELECT COUNT(*) FROM images").fetchone()[0]

    # ----------------------------- ingest ------------------------------- #
    def ingest(
        self,
        image_id: str,
        arr: np.ndarray,
        label: int,
        meta: dict,
        signer: Ed25519PrivateKey,
    ) -> str:
        \"\"\"Ingest one image: store pixels, hash, chain, and sign. Returns chain_hash.\"\"\"
        arr = np.ascontiguousarray(arr, dtype=np.uint8)
        image_sha = sha256_image(arr)

        last = self._last_row()
        seq = 0 if last is None else last[0] + 1
        prev_hash = GENESIS_PREV if last is None else last[1]
        chain_hash = compute_chain_hash(image_sha, prev_hash)

        signature = signer.sign(signed_payload(image_sha, label, meta)).hex()

        # persist pixels as PNG (lossless -> hash stays stable)
        file_path = self.image_store / f"{image_id}.png"
        Image.fromarray(arr).save(file_path)

        self.conn.execute(
            \"\"\"INSERT INTO images
               (image_id, seq, sha256, prev_hash, chain_hash, signature,
                label, meta, file_path, ingested_at)
               VALUES (?,?,?,?,?,?,?,?,?,?)\"\"\",
            (
                image_id, seq, image_sha, prev_hash, chain_hash, signature,
                int(label), json.dumps(meta, sort_keys=True),
                str(file_path), _dt.datetime.utcnow().isoformat(),
            ),
        )
        self.conn.commit()
        self._log(image_id, "ingest", "ok", f"seq={seq}")
        return chain_hash

    # --------------------------- verify + load -------------------------- #
    def verify_and_load(
        self, image_id: str, device_pub: Ed25519PublicKey
    ) -> tuple[Optional[np.ndarray], int, str]:
        \"\"\"
        Integrity + authenticity gate that the DataLoader calls.
        Returns (pixels|None, label, status). status is 'ok' or a failure reason.
        On any failure returns (None, -1, reason) so the loader can drop the sample.
        \"\"\"
        row = self.conn.execute(
            "SELECT sha256, chain_hash, prev_hash, signature, label, meta, file_path "
            "FROM images WHERE image_id=?",
            (image_id,),
        ).fetchone()
        if row is None:
            self._log(image_id, "verify", "fail", "not_found")
            return None, -1, "not_found"

        sha_db, chain_db, prev_db, sig_hex, label, meta_json, file_path = row
        meta = json.loads(meta_json)

        # 1) recompute image hash from stored file -> catches A1 tampering
        try:
            arr = np.ascontiguousarray(np.asarray(Image.open(file_path)), dtype=np.uint8)
        except Exception as e:  # noqa
            self._log(image_id, "verify", "fail", f"read_error:{e}")
            return None, -1, "read_error"

        sha_now = sha256_image(arr)
        if sha_now != sha_db:
            self._log(image_id, "verify", "fail", "hash_mismatch")
            return None, -1, "hash_mismatch"

        # 2) recompute chain link -> catches record tampering
        if compute_chain_hash(sha_db, prev_db) != chain_db:
            self._log(image_id, "verify", "fail", "chain_broken")
            return None, -1, "chain_broken"

        # 3) signature over {hash,label,meta} -> catches A2 label-flip & A3 wrong key
        try:
            device_pub.verify(bytes.fromhex(sig_hex), signed_payload(sha_db, label, meta))
        except InvalidSignature:
            self._log(image_id, "verify", "fail", "bad_signature")
            return None, -1, "bad_signature"

        self._log(image_id, "verify", "ok", "")
        return arr, int(label), "ok"

    # --------------------------- full chain scan ------------------------ #
    def verify_chain_full(self) -> dict:
        \"\"\"
        Walk the whole chain in seq order. Report first broken link (if any)
        and total verified. This produces the headline detection result.
        \"\"\"
        rows = self.conn.execute(
            "SELECT image_id, seq, sha256, prev_hash, chain_hash "
            "FROM images ORDER BY seq ASC"
        ).fetchall()

        prev = GENESIS_PREV
        for image_id, seq, sha, prev_db, chain_db in rows:
            if prev_db != prev:
                return {"valid": False, "first_broken": image_id, "seq": seq,
                        "reason": "prev_hash_mismatch", "verified": seq}
            if compute_chain_hash(sha, prev_db) != chain_db:
                return {"valid": False, "first_broken": image_id, "seq": seq,
                        "reason": "chain_hash_mismatch", "verified": seq}
            prev = chain_db

        return {"valid": True, "first_broken": None, "verified": len(rows)}

    def close(self) -> None:
        self.conn.close()""")





import os, glob, time, json, random, shutil
from pathlib import Path
import numpy as np, pandas as pd

# ---------------- experiment config ----------------
TARGET_POS    = "Pneumonia"    # try "Effusion"/"Atelectasis"/"Infiltration" for a larger set
PER_CLASS_CAP = 5000
IMG_SIZE      = 224
SEED          = 42
EPOCHS        = 5
BATCH         = 32
LR            = 1e-4
POISON_RATES  = [0.0, 0.05, 0.10, 0.20]
random.seed(SEED); np.random.seed(SEED)

WORK   = Path("/kaggle/working")
STORE  = WORK / "secure_store"
DBP    = WORK / "secure.db"
KEYS   = WORK / "keys"
RESULTS= WORK / "results"; RESULTS.mkdir(exist_ok=True, parents=True)
INPUT  = Path("/kaggle/input")
idxcol = "Image Index"

# ---- show what is actually mounted ----
tops = sorted(p.name for p in INPUT.glob("*"))
print("Attached under /kaggle/input:", tops or "(nothing — click Add Input and wait for the mount)")
assert tops, "No dataset mounted. Add Input -> NIH Chest X-rays, wait a few seconds, re-run."

# ---- robust recursive image index via os.walk (handles images_00X/images/*.png) ----
IMG_EXT = (".png", ".jpg", ".jpeg")
print("indexing images (walking the tree)...")
img_index = {}
for dirpath, _, files in os.walk(INPUT):
    for f in files:
        if f.lower().endswith(IMG_EXT):
            img_index.setdefault(f, os.path.join(dirpath, f))
print(f"indexed {len(img_index):,} images")
assert img_index, ("Still no images. The mount may not be ready — wait 10s and re-run, "
                   "or confirm images_001..012 appear in the right-hand data panel.")
print("sample image path:", next(iter(img_index.values())))

# ---- find the labels CSV (Data_Entry_2017.csv is in this dataset) ----
def find_label_csv():
    hits = glob.glob(str(INPUT/"**"/"Data_Entry_2017.csv"), recursive=True)
    if hits: return hits[0]
    for c in glob.glob(str(INPUT/"**"/"*.csv"), recursive=True):
        try:
            cols = [x.strip() for x in pd.read_csv(c, nrows=1).columns]
            if "Finding Labels" in cols and "Image Index" in cols:
                return c
        except Exception:
            pass
    return None

CSV = find_label_csv()
MODE = "csv" if CSV else "folderwise"
print("label source:", MODE, "|", CSV or "(none)")





from sklearn.model_selection import train_test_split

df = pd.read_csv(CSV)
df.columns = [c.strip() for c in df.columns]
labcol = "Finding Labels" if "Finding Labels" in df.columns else df.columns[1]
idxcol = "Image Index"   if "Image Index"   in df.columns else df.columns[0]

# keep only rows whose image we actually have on disk
df = df[df[idxcol].isin(img_index)].copy()

has_pos = df[labcol].str.contains(TARGET_POS, regex=False, na=False)
is_neg  = df[labcol].eq("No Finding")
pos, neg = df[has_pos].copy(), df[is_neg].copy()
print(f"available: {TARGET_POS}={len(pos):,}  No-Finding={len(neg):,}")

k = min(len(pos), len(neg), PER_CLASS_CAP)
pos = pos.sample(k, random_state=SEED); neg = neg.sample(k, random_state=SEED)
pos["y"], neg["y"] = 1, 0
data = pd.concat([pos, neg]).sample(frac=1, random_state=SEED).reset_index(drop=True)
data["path"] = data[idxcol].map(img_index)
print(f"balanced per-class k={k}  total={len(data)}")

trainval, test = train_test_split(data, test_size=0.15, stratify=data.y, random_state=SEED)
train, val = train_test_split(trainval, test_size=0.15/0.85, stratify=trainval.y, random_state=SEED)
for nm, d in [("train",train),("val",val),("test",test)]:
    print(f"{nm:5s} n={len(d):5d}  pos={int(d.y.sum()):4d}  neg={int((d.y==0).sum()):4d}")

split = {r[idxcol]: s for s, dd in [("train",train),("val",val),("test",test)] for _, r in dd.iterrows()}
data["split"] = data[idxcol].map(split)
data.to_csv(RESULTS / "split.csv", index=False)





from PIL import Image
import securedb
from securedb import SecureImageDB, generate_device_keypair, load_private_key, load_public_key

# fresh store each run
for p in (DBP, WORK/"secure.db-wal", WORK/"secure.db-shm"):
    if Path(p).exists(): Path(p).unlink()
if STORE.exists(): shutil.rmtree(STORE)

priv_path, pub_path = generate_device_keypair(KEYS)
signer   = load_private_key(priv_path)
device_pub = load_public_key(pub_path)

db = SecureImageDB(DBP, STORE)

t0 = time.time()
def load224(path):
    im = Image.open(path).convert("L").resize((IMG_SIZE, IMG_SIZE))
    return np.asarray(im, dtype=np.uint8)

for _, r in data.iterrows():
    arr = load224(r["path"])
    db.ingest(r[idxcol], arr, int(r.y),
              {"split": r["split"], "orig": r[idxcol], "device": "CXR-01"}, signer)
ingest_secs = time.time() - t0
print(f"ingested {db.count()} images in {ingest_secs:.1f}s  ({1000*ingest_secs/len(data):.2f} ms/img)")
print("chain check:", db.verify_chain_full())

store_mb = sum(f.stat().st_size for f in STORE.glob('*.png'))/1e6
print(f"secure store size: {store_mb:.1f} MB")





import torch, torch.nn as nn
from torch.utils.data import Dataset, DataLoader
import torchvision as tv
from torchvision import transforms

device = "cuda" if torch.cuda.is_available() else "cpu"
print("device:", device)

MEAN=[0.485,0.456,0.406]; STD=[0.229,0.224,0.225]
tf = transforms.Compose([
    transforms.ToPILImage(),
    transforms.Grayscale(num_output_channels=3),
    transforms.ToTensor(),
    transforms.Normalize(MEAN, STD),
])

class CXRDataset(Dataset):
    """mode='unsecured' reads the file directly; mode='secured' routes through verify_and_load."""
    def __init__(self, ids, mode="secured"):
        self.ids = list(ids); self.mode = mode
    def __len__(self): return len(self.ids)
    def __getitem__(self, i):
        iid = self.ids[i]
        if self.mode == "secured":
            arr, label, status = db.verify_and_load(iid, device_pub)
            if status != "ok":                       # rejected sample -> mask out
                arr = np.zeros((IMG_SIZE,IMG_SIZE), np.uint8); label = 0
        else:
            row = db.conn.execute("SELECT file_path,label FROM images WHERE image_id=?", (iid,)).fetchone()
            arr = np.asarray(Image.open(row[0]), dtype=np.uint8); label = int(row[1])
        return tf(arr), label

def ids_for(sp): return list(data[data.split==sp][idxcol])
def make_loader(sp, mode, shuffle):
    return DataLoader(CXRDataset(ids_for(sp), mode), batch_size=BATCH,
                      shuffle=shuffle, num_workers=2, pin_memory=True)





from sklearn.metrics import roc_auc_score, f1_score, accuracy_score

def build_model():
    m = tv.models.resnet50(weights=tv.models.ResNet50_Weights.IMAGENET1K_V2)
    m.fc = nn.Linear(m.fc.in_features, 2)
    return m.to(device)

def train(model, loader, epochs=EPOCHS):
    opt = torch.optim.AdamW(model.parameters(), lr=LR)
    lossf = nn.CrossEntropyLoss(); scaler = torch.cuda.amp.GradScaler()
    model.train()
    for ep in range(epochs):
        tot=0
        for x,y in loader:
            x,y = x.to(device), y.to(device)
            opt.zero_grad()
            with torch.cuda.amp.autocast():
                loss = lossf(model(x), y)
            scaler.scale(loss).backward(); scaler.step(opt); scaler.update()
            tot += loss.item()*x.size(0)
        print(f"  epoch {ep+1}/{epochs}  loss={tot/len(loader.dataset):.4f}")
    return model

@torch.no_grad()
def evaluate(model, loader):
    model.eval(); P,Y=[],[]
    for x,y in loader:
        p = torch.softmax(model(x.to(device)),1)[:,1].cpu().numpy()
        P += p.tolist(); Y += y.tolist()
    P=np.array(P); Y=np.array(Y); pred=(P>=0.5).astype(int)
    return {"acc":accuracy_score(Y,pred), "auc":roc_auc_score(Y,P), "f1":f1_score(Y,pred)}

torch.manual_seed(SEED)
model = build_model()
print("training baseline (secured loader)...")
train(model, make_loader("train","secured",True))
metrics_secured = evaluate(model, make_loader("test","secured",False))
metrics_unsec_eval = evaluate(model, make_loader("test","unsecured",False))
print("secured-loader test  :", {k:round(v,4) for k,v in metrics_secured.items()})
print("unsecured-loader test:", {k:round(v,4) for k,v in metrics_unsec_eval.items()})
torch.save(model.state_dict(), RESULTS/"resnet50_baseline.pt")





def time_epoch(mode):
    ld = make_loader("train", mode, False)
    t0=time.time()
    for x,y in ld: _=x.shape
    return time.time()-t0

t_un  = time_epoch("unsecured")
t_sec = time_epoch("secured")
n_train = len(ids_for("train"))
overhead = {
    "ingest_ms_per_img": round(1000*ingest_secs/len(data),3),
    "store_MB": round(store_mb,1),
    "epoch_unsecured_s": round(t_un,2),
    "epoch_secured_s": round(t_sec,2),
    "verify_overhead_pct": round(100*(t_sec-t_un)/t_un,1),
    "verify_ms_per_img": round(1000*(t_sec-t_un)/n_train,3),
}
print(json.dumps(overhead, indent=2))





import sqlite3
from securedb import sha256_image
# work on a copy so the trained pipeline is untouched
DBP2 = WORK/"secure_attacked.db"; STORE2 = WORK/"secure_store_atk"
if STORE2.exists(): shutil.rmtree(STORE2)
shutil.copytree(STORE, STORE2)
for p in (DBP2, WORK/"secure_attacked.db-wal", WORK/"secure_attacked.db-shm"):
    if Path(p).exists(): Path(p).unlink()
shutil.copyfile(DBP, DBP2)

db2 = SecureImageDB(DBP2, STORE2)
# repoint stored file_paths to the copied store
db2.conn.execute("UPDATE images SET file_path = REPLACE(file_path, ?, ?)",
                 (str(STORE), str(STORE2))); db2.conn.commit()
all_ids = [r[0] for r in db2.conn.execute("SELECT image_id FROM images").fetchall()]
rng = np.random.default_rng(SEED)

def sample_ids(n): return list(rng.choice(all_ids, size=n, replace=False))

# --- A1: tamper stored pixels ---
a1 = sample_ids(50)
for iid in a1:
    fp = db2.conn.execute("SELECT file_path FROM images WHERE image_id=?", (iid,)).fetchone()[0]
    arr = np.asarray(Image.open(fp)).copy(); arr[:25,:25] = 0
    Image.fromarray(arr).save(fp)
a1_det = sum(db2.verify_and_load(i, device_pub)[2]=="hash_mismatch" for i in a1)

# --- A2: label-flip in DB (no re-sign) ---
a2 = [i for i in sample_ids(60) if i not in a1][:50]
for iid in a2:
    cur = db2.conn.execute("SELECT label FROM images WHERE image_id=?", (iid,)).fetchone()[0]
    db2.conn.execute("UPDATE images SET label=? WHERE image_id=?", (1-cur, iid))
db2.conn.commit()
a2_det = sum(db2.verify_and_load(i, device_pub)[2]=="bad_signature" for i in a2)

# --- A3: unauthenticated injection (attacker key) ---
from securedb import Ed25519PrivateKey
attacker = Ed25519PrivateKey.generate()
a3 = []
for j in range(50):
    iid=f"evil_{j:03d}"; a3.append(iid)
    db2.ingest(iid, rng.integers(0,256,(IMG_SIZE,IMG_SIZE),np.uint8), 0, {"device":"ROGUE"}, attacker)
a3_det = sum(db2.verify_and_load(i, device_pub)[2]=="bad_signature" for i in a3)

detection = {
    "A1_tamper":      {"n":len(a1), "detected":a1_det, "rate":round(a1_det/len(a1),3)},
    "A2_labelflip":   {"n":len(a2), "detected":a2_det, "rate":round(a2_det/len(a2),3)},
    "A3_injection":   {"n":len(a3), "detected":a3_det, "rate":round(a3_det/len(a3),3)},
}
print(json.dumps(detection, indent=2))
print("full-chain scan on attacked DB:", db2.verify_chain_full())





def poisoned_loader(rate):
    ids = ids_for("train"); y = {i:int(data[data[idxcol]==i].y.iloc[0]) for i in ids}
    flip = set(rng.choice(ids, size=int(rate*len(ids)), replace=False)) if rate>0 else set()
    class PDS(Dataset):
        def __len__(self): return len(ids)
        def __getitem__(self, k):
            iid=ids[k]
            row=db.conn.execute("SELECT file_path FROM images WHERE image_id=?", (iid,)).fetchone()
            arr=np.asarray(Image.open(row[0]),dtype=np.uint8)
            lab=y[iid] ^ (1 if iid in flip else 0)
            return tf(arr), lab
    return DataLoader(PDS(), batch_size=BATCH, shuffle=True, num_workers=2, pin_memory=True)

poison_curve=[]
for rate in POISON_RATES:
    torch.manual_seed(SEED)
    m = build_model()
    print(f"poison rate {rate:.0%} ...")
    train(m, poisoned_loader(rate), epochs=EPOCHS)
    met = evaluate(m, make_loader("test","unsecured",False))
    poison_curve.append({"rate":rate, **{k:round(v,4) for k,v in met.items()}})
    print("  ->", poison_curve[-1])
pd.DataFrame(poison_curve).to_csv(RESULTS/"poison_curve.csv", index=False)





